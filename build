#!/usr/bin/env sh
# Build script for desktop (PC) target
# Usage:
#   ./build         # builds using Makefile.pc
#   ./build clean   # cleans the build output

set -e

if [ "$1" = "clean" ]; then
    make -f Makefile.pc clean
    exit 0
fi

# Always clean before building when no explicit target is provided.
if [ -z "$1" ]; then
    make -f Makefile.pc clean
fi

make -f Makefile.pc "$@"
